# OAuth 사용을 위한 클라이언트 자격 증명 (Notion Developer)
NOTION_CLIENT_ID="발급받은_Oauth_클라이언트_ID_입력"
NOTION_CLIENT_SECRET="발급받은_Oauth_시크릿_입력"

# 노션 개발자 대시보드에 적은 리디렉션 주소와 동일해야 합니다.
REDIRECT_URI="http://localhost:5000/callback"

# (신규) OpenAI API 키 설정! 이 키가 있어야 AI 퀴즈가 생성됩니다.
OPENAI_API_KEY="sk-...여기에_키를_입력하세요"

# (옵션) 나중에 Local LLM(Ollama 등)을 연동할 경우 아래 주석을 풀고 베이스 URL을 교체하세요.
# OPENAI_API_BASE="http://localhost:11434/v1"
